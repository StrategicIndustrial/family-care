NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ANTHROPIC_API_KEY=sk-ant-...
ADMIN_PASSWORD=change-me
FAMILY_INVITE_CODE=FAM-2026-XXXX
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-...
CALENDAR_TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Web Push (medication reminders) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:you@example.com

# Shared secret checked on /api/cron/medication-reminders so only the
# Supabase pg_cron job (via pg_net) can trigger it — generate with:
# openssl rand -base64 32
CRON_SECRET=generate-with-openssl-rand-base64-32
